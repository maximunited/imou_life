        "default": "mdi:television-ambient-light"
      },
      "close_camera": {
        "default": "mdi:camera-off"
      },
      "link_dev_alarm": {
        "default": "mdi:bell"
      },
      "white_light": {
        "default": "mdi:light-flood-down"
      },
      "smart_track": {
        "default": "mdi:radar"
      },
      "linkagewhitelight": {
        "default": "mdi:light-flood-down"
      },
      "linkage_white_light": {
        "default": "mdi:lightbulb-on"
      },
      "audio_encode_control": {
        "default": "mdi:audio-input-rca"
      },
      "push_notifications": {
        "default": "mdi:bell-ring",
        "state": {
          "on": "mdi:webhook",
          "off": "mdi:webhook-off"
        }
      },
      "power_saving_mode": {
        "default": "mdi:battery-saver"
      },
      "auto_sleep": {
        "default": "mdi:power-sleep"
      },
      "led_indicators": {
        "default": "mdi:led-variant-outline",
        "state": {
          "on": "mdi:led-variant-on",
          "off": "mdi:led-variant-off"
        }
      }
    },
    "button": {
      "restart_device": {
        "default": "mdi:restart"
      },
      "refresh_data": {
        "default": "mdi:refresh"
      },
      "refresh_alarm": {
        "default": "mdi:alarm-bell"
      },
      "enter_sleep_mode": {
        "default": "mdi:sleep"
      },
      "exit_sleep_mode": {
        "default": "mdi:sleep-off"
      },
      "optimize_battery": {
        "default": "mdi:battery-settings"
      },
      "reset_power_settings": {
        "default": "mdi:refresh-circle"
      }
    },
    "siren": {
      "siren": {
        "default": "mdi:alarm-light",
        "state": {
          "on": "mdi:alarm-light",
          "off": "mdi:alarm-light-outline"
        }
      }
    },
    "camera": {
      "camera": {
        "default": "mdi:video"
      },
      "camera_sd": {
        "default": "mdi:video"
      }
    }
  },
  "services": {
    "ptz_location": {
      "service": "mdi:crosshairs-gps"
    },
    "ptz_move": {
      "service": "mdi:cursor-move"
    }
