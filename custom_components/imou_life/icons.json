{
  "entity": {
    "sensor": {
      "last_alarm": {
        "default": "mdi:timer"
      },
      "storage_used": {
        "default": "mdi:harddisk"
      },
      "callback_url": {
        "default": "mdi:webhook"
      },
      "status": {
        "default": "mdi:lan-connect",
        "state": {
          "online": "mdi:check-network",
          "offline": "mdi:close-network",
          "sleep": "mdi:sleep",
          "upgrading": "mdi:cloud-arrow-up"
        }
      },
      "battery": {
        "default": "mdi:battery"
      },
      "battery_level": {
        "default": "mdi:battery",
        "range": {
          "0": "mdi:battery-outline",
          "10": "mdi:battery-10",
          "20": "mdi:battery-20",
          "30": "mdi:battery-30",
          "40": "mdi:battery-40",
          "50": "mdi:battery-50",
          "60": "mdi:battery-60",
          "70": "mdi:battery-70",
          "80": "mdi:battery-80",
          "90": "mdi:battery-90",
          "100": "mdi:battery"
        }
      },
      "battery_voltage": {
        "default": "mdi:flash"
      },
      "power_consumption": {
        "default": "mdi:lightning-bolt"
      },
      "sleep_mode": {
        "default": "mdi:power-sleep"
      },
      "power_saving_status": {
        "default": "mdi:battery-saver"
      },
      "api_status": {
        "default": "mdi:api",
        "state": {
          "ok": "mdi:check-circle",
          "rate_limited": "mdi:speedometer-slow",
          "error": "mdi:alert-circle",
          "unknown": "mdi:help-circle"
        }
      }
    },
    "binary_sensor": {
      "online": {
        "default": "mdi:lan-connect",
        "state": {
          "on": "mdi:check-network",
          "off": "mdi:close-network"
        }
      },
      "motion_alarm": {
        "default": "mdi:motion-sensor",
        "state": {
          "on": "mdi:motion-sensor-alert",
          "off": "mdi:motion-sensor"
        }
      },
      "low_battery": {
        "default": "mdi:battery",
        "state": {
          "on": "mdi:battery-alert",
          "off": "mdi:battery"
        }
      },
      "charging": {
        "default": "mdi:battery",
        "state": {
          "on": "mdi:battery-charging",
          "off": "mdi:battery"
        }
      },
      "power_saving_active": {
        "default": "mdi:battery-saver",
        "state": {
          "on": "mdi:battery-saver",
          "off": "mdi:battery-saver-outline"
        }
      },
      "sleep_mode_active": {
        "default": "mdi:power-sleep",
        "state": {
          "on": "mdi:power-sleep",
          "off": "mdi:sleep-off"
        }
      }
    },
    "select": {
      "night_vision_mode": {
        "default": "mdi:weather-night"
      },
      "power_mode": {
        "default": "mdi:battery-settings"
      },
      "recording_quality": {
        "default": "mdi:quality-high"
      },
      "motion_sensitivity_level": {
        "default": "mdi:tune-vertical"
      },
      "motion_sensitivity": {
        "default": "mdi:tune-vertical"
      },
      "sleep_schedule": {
        "default": "mdi:clock-outline"
      }
